# Haia — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Database (Railway PostgreSQL plugin auto-provisions this) ───
DATABASE_URL="postgresql://user:password@host:5432/haia"

# ─── Redis (Railway Redis plugin, used by background sync worker) ───
REDIS_URL="redis://default:password@host:6379"

# ─── Auth (NextAuth v5) ───
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── MetaApi ───
# Get your token(s) at https://app.metaapi.cloud
# Option 1: Single token for everything (simple)
METAAPI_TOKEN=""
# Option 2: Separate tokens to avoid rate limit conflicts (recommended)
# Signals token: used for streaming connections, trade execution, breakeven
METAAPI_TOKEN_SIGNALS=""
# Analytics token: used for trade sync, historical deals, account info
METAAPI_TOKEN_ANALYTICS=""

# ─── Google OAuth (optional — leave blank to disable) ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Telegram (from https://my.telegram.org) ───
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ─── TradingView Webhook (offset data — must match your Pine Script indicator) ───
# Generate with: openssl rand -hex 16
TRADINGVIEW_WEBHOOK_SECRET=

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Haia"
