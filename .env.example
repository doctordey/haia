# Rename this file to .env before use
# cp env.example .env

# Database (Railway PostgreSQL plugin auto-provisions this)
DATABASE_URL="postgresql://user:password@host:5432/haia?schema=public"

# Redis (Railway Redis plugin auto-provisions this)
REDIS_URL="redis://default:password@host:6379"

# Auth (NextAuth v5 uses AUTH_SECRET; set both for compatibility)
AUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"  # same value as AUTH_SECRET
NEXTAUTH_URL="http://localhost:3000"  # Change to Railway URL in production

# MetaApi — Get your token at https://app.metaapi.cloud
METAAPI_TOKEN=""

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"  # Change to Railway URL in production
NEXT_PUBLIC_APP_NAME="Haia"
