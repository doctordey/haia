# Haia — Environment Variables
# Copy this file to .env and fill in the values.

# ─── Database (Railway PostgreSQL plugin auto-provisions this) ───
DATABASE_URL="postgresql://user:password@host:5432/haia"

# ─── Redis (Railway Redis plugin, used by background sync worker) ───
REDIS_URL="redis://default:password@host:6379"

# ─── Auth (NextAuth v5) ───
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_SECRET="generate-a-random-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── MetaApi ───
# Get your token at https://app.metaapi.cloud
METAAPI_TOKEN=""

# ─── Google OAuth (optional — leave blank to disable) ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Haia"
